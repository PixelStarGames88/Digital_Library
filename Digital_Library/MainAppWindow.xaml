<Window x:Class="Digital_Library.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Digital_Library"
        mc:Ignorable="d"
        Title="Виртуальная библиотека" Height="455" Width="653" FontFamily="Sitka Text" Background="#FF720024" FontSize="18" Icon="/Icons/library_icon.ico">

    <DockPanel Margin="0,0,0,6">
        <DockPanel DockPanel.Dock="Top" Background="#FF8F0933" Height="81">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Выйти" Click="BtnLogout_Click" Width="80" Height="27" Margin="10,0" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>

                <StackPanel x:Name="ActionPanel" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="10,0">
                    <TextBox x:Name="SearchBox" Width="185" Height="34" VerticalAlignment="Center" TextChanged="SearchBox_TextChanged"/>
                    <Button x:Name="Find" Background="#FF720024" Width="35" Height="34" Click="Find_Click">
                        <Image Source="/Icons/loupe.png" Height="31" Width="35"/>
                    </Button>
                </StackPanel>
            </Grid>
        </DockPanel>

        <TabControl x:Name="MainTabs" Margin="10">
        </TabControl>
    </DockPanel>

</Window>

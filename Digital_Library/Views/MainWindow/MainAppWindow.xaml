<Window x:Class="Digital_Library.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Виртуальная библиотека" Height="580" Width="898" FontFamily="Sitka Text" Background="#FF720024" FontSize="18" Icon="/Icons/library_icon.ico">

    <DockPanel Margin="0,0,0,6">

        <DockPanel DockPanel.Dock="Top" Background="#FF8F0933" Height="81">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Выйти" Click="BtnLogout_Click" Width="90" Height="35" Margin="10,0,10,0" VerticalAlignment="Center" FontSize="18" FontWeight="Bold"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <Button Content="Сохранить результат поиска" Click="BtnSaveResult_Click" Width="299" Height="35" Margin="0,0,10,0" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </DockPanel>

        <StackPanel DockPanel.Dock="Top" Background="#FF99153D" Height="90" Orientation="Horizontal" Margin="0,5">
            <StackPanel Margin="10,5">
                <TextBlock Text="Название:" FontSize="14" Foreground="White"/>
                <TextBox x:Name="NameSearchBox" Width="180" Height="25" TextChanged="Filter_Changed" HorizontalAlignment="Left"/>
            </StackPanel>
            <StackPanel Margin="10,5">
                <TextBlock Text="Ключевые слова/аннотация:" FontSize="14" Foreground="White"/>
                <TextBox x:Name="WordsSearchBox" Width="200" Height="25" TextChanged="Filter_Changed" HorizontalAlignment="Left"/>
            </StackPanel>
            <StackPanel Margin="10,5">
                <TextBlock Text="Год:" FontSize="14" Foreground="White"/>
                <ComboBox x:Name="FilterYears" Width="90" Height="25" HorizontalAlignment="Left" SelectionChanged="Filter_Changed"/>
            </StackPanel>
            <StackPanel Margin="10,5">
                <TextBlock Text="Авторы:" FontSize="14" Foreground="White"/>
                <ComboBox x:Name="FilterAuthors" Width="160" Height="25" HorizontalAlignment="Left" SelectionChanged="Filter_Changed"/>
            </StackPanel>
            <StackPanel Margin="10,5">
                <TextBlock Text="Количество страниц:" FontSize="14" Foreground="White"/>
                <TextBox x:Name="FilterPageCount" Width="90" Height="25" TextChanged="Filter_Changed" HorizontalAlignment="Left"/>
            </StackPanel>
        </StackPanel>

        <TabControl x:Name="MainTabs" Margin="10" SelectionChanged="MainTabs_SelectionChanged"/>

    </DockPanel>
</Window>